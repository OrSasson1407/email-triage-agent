# ═══════════════════════════════════════════════════
#  Email Triage Agent — Environment Variables
#  Copy this file to .env and fill in your values
#  All services below have FREE tiers
# ═══════════════════════════════════════════════════

# ── Google Gemini AI (FREE) ─────────────────────────
# Get key: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=1000
GEMINI_TIMEOUT_SECONDS=30

# ── Gmail OAuth2 (FREE) ─────────────────────────────
# Setup: https://console.cloud.google.com
#   1. Create project
#   2. Enable Gmail API
#   3. Create OAuth2 credentials (Desktop app)
#   4. Run: go run scripts/setup_oauth.go
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_USER_EMAIL=you@gmail.com

# ── Upstash Redis (FREE) ────────────────────────────
# Setup: https://upstash.com → Create Database → REST API
# Free tier: 10,000 commands/day
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
REDIS_TTL_HOURS=72
# Use in-memory fallback instead of Redis (no setup needed):
# REDIS_URL=memory

# ── Neon PostgreSQL (FREE) ──────────────────────────
# Setup: https://neon.tech → Create Project → Connection string
# Free tier: 512 MB storage, 3 GB transfer/month
POSTGRES_URL=postgres://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
POSTGRES_MAX_CONNS=3

# ── Slack (FREE) ────────────────────────────────────
# Setup: https://api.slack.com/apps
#   1. Create App → From scratch
#   2. Incoming Webhooks → Activate → Add to channel
#   3. Copy webhook URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXX
SLACK_CHANNEL=#email-urgent

# ── Gmail SMTP for Email Digest (FREE) ──────────────
# Setup: Gmail → Settings → See all settings
#   → Security → 2-Step Verification → App Passwords
#   → Select app: Mail → Generate → copy 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
DIGEST_RECIPIENT=you@gmail.com

# ── VIP Senders ─────────────────────────────────────
# Comma-separated emails or domains — always treated as HIGH urgency
# Supports exact match (user@domain.com) or domain (@domain.com)
VIP_SENDERS=boss@company.com,cto@company.com,@important-client.com
# Or load from file (one per line, # = comment):
# VIP_SENDERS_FILE=/app/vip.txt

# ── Scheduler ───────────────────────────────────────
# Tuned to stay within free tier limits:
#   30 runs/day × 40 emails × 1 Gemini call = 1,200/day (free cap: 1,500)
POLL_INTERVAL=@every 48m
MAX_EMAILS_PER_RUN=40
WORKER_COUNT=3
DIGEST_CRON=0 18 * * *

# ── HTTP API ────────────────────────────────────────
API_PORT=8080
# Change this to a strong random secret:
API_SECRET=change_this_to_a_long_random_secret_string

# ── Classification Thresholds ───────────────────────
# Minimum confidence to trigger each action:
URGENCY_HIGH_CONFIDENCE=0.80   # send Slack alert
AUTO_DRAFT_CONFIDENCE=0.90     # save reply draft in Gmail
AUTO_ARCHIVE_CONFIDENCE=0.95   # auto-archive LOW urgency emails

# ── Feature Flags ───────────────────────────────────
ENABLE_THREAD_CONTEXT=true     # include previous emails in classification
ENABLE_VIP_FAST_PATH=true      # skip Gemini for VIP senders
DRY_RUN=false                  # true = classify but don't modify Gmail